# Game Master Configuration
# Copy this file to .env and fill in the actual values

# LLM Provider URL (llama.cpp endpoint)
LLAMA_CPP_URL=http://llama.cpp:8090/v1

# Pixelle-MCP Server URL
PIXELLE_MCP_URL=http://pixelle-mcp:9004/pixelle/mcp

# Game Master Mode
# - single: Run one daily cycle and exit
# - simulation: Run continuous cycles with timing for testing
# - scheduled: Run on daily schedule at 8:00 AM
GAME_MASTER_MODE=single