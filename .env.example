# AI-GAMES Configuration
# Copy this file to .env and fill in the actual values

# User ID and Group ID for ComfyUI container (prevents permission issues)
# Set to your current user ID: id -u and id -g
UID=1000
GID=1000

# LLM Provider URL (llama.cpp endpoint)
LLM_URL=http://llama.cpp:8090/v1

# Placeholder API key for llama.cpp (required by OpenAI client, but not used by llama.cpp)
LLM_API_KEY=placeholder-key-for-llama-cpp

# LLM model used for generation
LLM_MODEL=Qwen/Qwen3.5-35B-FP8

# Pixelle-MCP Server URL
PIXELLE_MCP_URL=http://pixelle-mcp:9004/pixelle/mcp

# ComfyUI URL
COMFYUI_URL=http://comfyui:8188

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Game Master Telegram User ID (user who can send admin commands like /start-game, /kick)
# The bot will only process GM commands from this user
TELEGRAM_BOT_GAME_MASTER_ID=your_telegram_user_id


# Telegram Bot SOCKS5 Proxy (optional)
# Leave empty for direct connection
# For SSH tunnel (ssh -D 9999), use: host.docker.internal:9999
# Format: host:port or socks5://user:pass@host:port
TELEGRAM_SOCKS_PROXY=

# Game Server API URL (internal docker network)
GAME_SERVER_URL=http://game-server:8000

# Game Schedule Interval
# Format: Nh (every N hours), Nm (every N minutes), Ns (every N seconds),
#        HH:MM (daily at that time), HH:MM,HH:MM,... (multiple times per day),
#        DAY-HH:MM,... (multi-daily by weekday: mon/tue/wed/thu/fri/sat/sun)
# Examples:
#   8h                          — run every 8 hours
#   30m                         — run every 30 minutes
#   08:00                       — run daily at 8 AM
#   08:00,12:00,14:00           — run daily at 8 AM, 12 PM, 2 PM
#   mon-08:00,wed-12:00,fri-20:00 — run Mon 8 AM, Wed 12 PM, Fri 8 PM
GAME_SCHEDULE=8h

# Game Master Mode
# - single: Run one cycle and exit
# - scheduled: Run on schedule (default)
GAME_SCHEDULER_MODE=scheduled

# Game Language
# - en: English
# - ru: Russian
GAME_LANGUAGE=ru

# Game ID for scheduler (which game to manage)
# Default: default_game (single game mode)
GAME_ID=default_game

# Minimum number of live players required to start the game
# Unfilled roles are occupied by NPCs
# New live players can replace NPCs
GAME_START_MIN_PLAYERS=3

# Maximum number of players allowed in a game (default: 10)
# When full, new players can only join if a slot opens up
GAME_START_MAX_PLAYERS=10

# Onboarding Interview Configuration
# Number of questions in the onboarding interview (default: 5)
ONBOARDING_QUESTIONS_COUNT=5
# Number of answer options per question (default: 5)
ONBOARDING_OPTIONS_COUNT=5

# Species Hybrid Detection Threshold
# 0.25 = if second species has >= 25% of first-place votes, character is a hybrid.
# Range: 0.0 (always hybrid) to 1.0 (only tie).
GAME_SPECIES_HYBRID_THRESHOLD=0.25

# Gender Hybrid Detection Threshold
# 0.25 = if second gender has >= 25% of first-place votes, character is hybrid.
# Range: 0.0 (always hybrid) to 1.0 (only tie).
GAME_GENDER_HYBRID_THRESHOLD=0.25

# LLM Generation Settings
# Maximum tokens for LLM responses (includes both reasoning and content for Qwen models)
# Default: 32768 - Qwen models consume tokens on thinking/reasoning before outputting content
LLM_MAX_TOKENS=32768
# Maximum tokens for avatar prompt generation (separate because it uses strict JSON schema output)
# Default: 4096
LLM_MAX_AVATAR_TOKENS=4096

# Parallel LLM calls for briefings and NPC decisions
# How many player/NPC briefings to generate concurrently
# Higher = faster but more load on the LLM provider
LLM_PARALLEL=2

# Turn consequence balance
# How many of each action type the LLM should generate per turn
# Total actions = PROGRESS + INJURY + FATAL
GAME_TURN_PROGRESS_ACTIONS=2
GAME_TURN_INJURY_ACTIONS=2
GAME_TURN_FATAL_ACTIONS=1
