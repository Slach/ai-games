# AI-GAMES Configuration
# Copy this file to .env and fill in the actual values

# LLM Provider URL (llama.cpp endpoint)
LLAMA_CPP_URL=http://llama.cpp:8090/v1

# Placeholder API key for llama.cpp (required by OpenAI client, but not used by llama.cpp)
LLAMA_CPP_API_KEY=placeholder-key-for-llama-cpp

# Pixelle-MCP Server URL
PIXELLE_MCP_URL=http://pixelle-mcp:9004/pixelle/mcp

# ComfyUI URL
COMFYUI_URL=http://comfyui:8188

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Game Master API URL (internal docker network)
GAME_MASTER_API_URL=http://game-master-api:8000

# Game Schedule Time (24h format, e.g., 08:00 for 8 AM)
GAME_SCHEDULE_TIME=08:00

# Game Master Mode
# - single: Run one daily cycle and exit
# - simulation: Run continuous cycles with timing for testing
# - scheduled: Run on daily schedule
GAME_MASTER_MODE=scheduled

# Game Language
# - en: English
# - ru: Russian
GAME_LANGUAGE=ru