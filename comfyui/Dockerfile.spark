# syntax=docker/dockerfile:1-labs
ARG NPROC=8
ARG UBUNTU_VERSION=24.04
ARG CUDA_VERSION=13.0.2

FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu${UBUNTU_VERSION} AS base

# Install minimal system dependencies
RUN apt update && apt install -y \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    git \
    wget \
    curl \
    build-essential \
    libgomp1 \
    ffmpeg \
    && apt autoremove && apt clean && rm -rf /var/lib/apt/lists/*

# Clone ComfyUI
RUN git clone --depth 1 https://github.com/comfyanonymous/ComfyUI.git /opt/ComfyUI
WORKDIR /opt/ComfyUI

# Create virtual environment with system site packages
RUN python3 -m venv --system-site-packages /opt/ComfyUI/.venv

# Install PyTorch 2.9 nightly with CUDA 13.0 support (ARM64) using pip inside venv
RUN /opt/ComfyUI/.venv/bin/pip install --upgrade pip && \
    /opt/ComfyUI/.venv/bin/pip install torch torchvision torchaudio torchcodec \
    --index-url https://download.pytorch.org/whl/nightly/cu130

# Install ComfyUI requirements (excluding torch packages)
RUN grep -vE '^\s*#' requirements.txt | grep -viE '^\s*(torch|torchvision|torchaudio)\b' > /opt/ComfyUI/requirements.no_torch.txt && \
    /opt/ComfyUI/.venv/bin/pip install -r /opt/ComfyUI/requirements.no_torch.txt

# Install ComfyUI Manager
RUN git clone --depth 1 https://github.com/Comfy-Org/ComfyUI-Manager.git /opt/ComfyUI/custom_nodes/ComfyUI-Manager && \
    /opt/ComfyUI/.venv/bin/pip install -r /opt/ComfyUI/custom_nodes/ComfyUI-Manager/requirements.txt

# Install KJNodes (advanced custom nodes for various workflows)
RUN git clone --depth 1 https://github.com/kijai/ComfyUI-KJNodes.git /opt/ComfyUI/custom_nodes/ComfyUI-KJNodes && \
    /opt/ComfyUI/.venv/bin/pip install -r /opt/ComfyUI/custom_nodes/ComfyUI-KJNodes/requirements.txt 2>/dev/null || true

# Install IP-Adapter custom nodes (for image reference / style transfer)
RUN git clone --depth 1 https://github.com/cubiq/ComfyUI_IPAdapter_plus.git /opt/ComfyUI/custom_nodes/ComfyUI_IPAdapter_plus

# Install ComfyUI-GGUF (GGUF model loader — required for Qwen-Image-Edit-2511
# GGUF quantized models; provides the UnetLoaderGGUF node)
RUN git clone --depth 1 https://github.com/city96/ComfyUI-GGUF.git /opt/ComfyUI/custom_nodes/ComfyUI-GGUF && \
    /opt/ComfyUI/.venv/bin/pip install -r /opt/ComfyUI/custom_nodes/ComfyUI-GGUF/requirements.txt

# Fix outdated channel URLs (ltdrdata -> Comfy-Org) in Manager source
RUN sed -i 's|https://raw.githubusercontent.com/ltdrdata/ComfyUI-Manager/main|https://raw.githubusercontent.com/Comfy-Org/ComfyUI-Manager/main|g' \
    /opt/ComfyUI/custom_nodes/ComfyUI-Manager/channels.list.template && \
    sed -i 's|https://raw.githubusercontent.com/ltdrdata/ComfyUI-Manager/main|https://raw.githubusercontent.com/Comfy-Org/ComfyUI-Manager/main|g' \
    /opt/ComfyUI/custom_nodes/ComfyUI-Manager/glob/manager_server.py

# Install comfy-cli
RUN /opt/ComfyUI/.venv/bin/pip install comfy-cli

# Fix permissions: runtime user (from compose's user: field) needs write access
# to .git directories inside custom_nodes for ComfyUI-Manager's .cnr-id files
RUN chmod -R a+rw /opt/ComfyUI/custom_nodes

EXPOSE 8188

ENV COMFYUI_PATH=/opt/ComfyUI/

CMD ["/opt/ComfyUI/.venv/bin/comfy", "--skip-prompt", "--no-enable-telemetry"]